#ifndef LIB_H
#define LIB_H

#ifdef __cplusplus
extern "C" {
#endif

#ifdef _WIN32
#  ifdef DLL_EXPORTS
#    define DLL_PUBLIC __declspec(dllexport)
#  else
#    define DLL_PUBLIC __declspec(dllimport)
#  endif
#else
#  define DLL_PUBLIC
#endif

DLL_PUBLIC int add(int x, int y);

#ifdef __cplusplus
}  // extern __cplusplus
#endif

#endif  // end of LIB_H

